#!/usr/bin/env bash
# claude-amq: launch Claude Code with AMQ co-op identity.
#
# Identity defaults to the git branch of CWD (= dux worktree name);
# falls back to "claude-<pid>" when not in a git worktree.
# Skips AMQ wrapping for oneshot (-p / --print) invocations.
# Uses the global queue at $AMQ_GLOBAL_ROOT and never auto-creates .amqrc
# in the worktree.
#
# Optional session-history seeding (OFF by default — see notes below):
#   When CLAUDE_AMQ_SEED_FROM_PARENT=1 is set AND we're in a git worktree
#   AND the worktree's Claude session dir is empty, copy the parent repo's
#   session JSONLs into it so `--resume` (interactive picker) can browse
#   past chats. Avoid combining with `--continue`: the latest parent
#   session may carry a deferred-tool marker that --continue refuses.
#   Pair with `resume_args = ["--resume"]` in dux config if enabling.
set -euo pipefail

# Locate the shared dux-amq lib dir (path-encode.sh, wake-launch.sh, ...).
# Search order: (1) $DUX_AMQ_LIB env var (set by bashrc-additions.sh),
# (2) ../lib relative to this script's resolved path (development checkout
# OR a side-by-side install), (3) common system locations. Fail loudly
# if the encoder isn't found — silent path-encoding mismatches were the
# whole point of audit01 P0-5.
_dux_amq_lib_locate() {
  if [[ -n "${DUX_AMQ_LIB:-}" && -f "$DUX_AMQ_LIB/path-encode.sh" ]]; then
    printf '%s' "$DUX_AMQ_LIB"; return 0
  fi
  local self_dir
  self_dir=$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")" && pwd)
  for candidate in \
    "$self_dir/../lib" \
    "$self_dir/../share/dux-amq/lib" \
    "/data/state/dux-amq/lib" \
    "/usr/local/share/dux-amq/lib" \
  ; do
    if [[ -f "$candidate/path-encode.sh" ]]; then
      printf '%s' "$(cd -- "$candidate" && pwd)"; return 0
    fi
  done
  return 1
}
DUX_AMQ_LIB_RESOLVED=$(_dux_amq_lib_locate) || {
  printf '\033[1;31m!\033[0m claude-amq: cannot locate dux-amq lib dir (path-encode.sh)\n' >&2
  printf '   set DUX_AMQ_LIB or reinstall dux-amq.\n' >&2
  exit 1
}
# Sourced from a runtime-resolved path; static analysis can't follow.
# shellcheck disable=SC1090,SC1091
source "$DUX_AMQ_LIB_RESOLVED/path-encode.sh"
# shellcheck disable=SC1090,SC1091
source "$DUX_AMQ_LIB_RESOLVED/wake-launch.sh"

warn() { printf '\033[1;33m!\033[0m %s\n' "$*" >&2; }

for arg in "$@"; do
  case "$arg" in
    -p|--print|--bare) exec claude "$@" ;;
  esac
done

seed_session_history() {
  # Off by default. Set CLAUDE_AMQ_SEED_FROM_PARENT=1 to enable.
  [[ "${CLAUDE_AMQ_SEED_FROM_PARENT:-}" == "1" ]] || return 0

  local git_dir git_common_dir main_worktree
  git_dir=$(git -C "$PWD" rev-parse --absolute-git-dir 2>/dev/null) || return 0
  git_common_dir=$(git -C "$PWD" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 0
  [[ "$git_dir" == "$git_common_dir" ]] && return 0
  main_worktree=$(git -C "$PWD" worktree list --porcelain 2>/dev/null \
    | awk '/^worktree / {print $2; exit}')
  [[ -z "$main_worktree" || "$main_worktree" == "$PWD" ]] && return 0

  local enc_self enc_main self_dir main_dir
  enc_self=$(path_encode "$PWD")
  enc_main=$(path_encode "$main_worktree")
  self_dir="$HOME/.claude/projects/$enc_self"
  main_dir="$HOME/.claude/projects/$enc_main"

  [[ ! -d "$main_dir" ]] && return 0
  if compgen -G "$self_dir/*.jsonl" >/dev/null 2>&1; then
    return 0
  fi

  mkdir -p "$self_dir"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a "$main_dir"/ "$self_dir"/ 2>/dev/null || true
  else
    cp -r "$main_dir"/. "$self_dir"/ 2>/dev/null || true
  fi
  local n
  n=$(find "$self_dir" -name '*.jsonl' 2>/dev/null | wc -l)
  echo "claude-amq: seeded $n past sessions from $main_worktree" >&2
}

# Allow tests to source this file without launching claude.
# Returns 0 when sourced (so test files can `source claude-amq && f`); falls
# through when executed.
(return 0 2>/dev/null) && return 0

seed_session_history || true

ME="${AM_ME:-}"
# Identity priority:
#   1. AM_ME from env (explicit override)
#   2. dux worktree dir basename — stable per-pane and unique, even if the
#      git branch was renamed or checked out to something unexpected
#   3. git branch (legacy fallback)
#   4. claude-<pid> (no-context fallback)
# Realpath-canonicalised containment: '$DUX_HOME/worktrees/' must be a
# strict ancestor of the resolved CWD. The boundary '/' rejects sibling
# directories like '$DUX_HOME/worktrees-evil/x' which the previous prefix
# glob `"$DUX_HOME/worktrees/"*` matched (audit01 P0-5).
if [[ -z "$ME" ]]; then
  _DUX_WTS=$(realpath -m "${DUX_HOME:-/data/state/dux}/worktrees")
  _PWD_REAL=$(realpath -m "$PWD")
  if [[ "$_PWD_REAL" == "$_DUX_WTS"/* ]]; then
    ME=$(basename "$_PWD_REAL")
  fi
  unset _DUX_WTS _PWD_REAL
fi
if [[ -z "$ME" ]]; then
  ME=$(git -C "$PWD" branch --show-current 2>/dev/null || true)
fi
[[ -z "$ME" ]] && ME="claude-$$"
# AMQ requires lowercase agent handles.
ME=$(printf '%s' "$ME" | tr '[:upper:]' '[:lower:]' | sed 's|[^a-z0-9_-]|-|g; s|^-\+||; s|-\+$||')

ROOT="${AMQ_GLOBAL_ROOT:-/data/state/amq}"

# Every interactive claude pane gets --dangerously-skip-permissions by
# default. Set CLAUDE_AMQ_SAFE=1 to opt out (e.g. when working in a
# repo where you want to confirm each tool call).
EXTRA=()
if [[ "${CLAUDE_AMQ_SAFE:-}" != "1" ]]; then
  EXTRA+=(--dangerously-skip-permissions)
fi

# Start the wake-up daemon with --inject-mode=raw so messages arrive as
# plain text + CR, which Claude Code (Ink-based) auto-submits. The
# default `auto` mode sometimes picks `paste`, which types but doesn't
# send. wake_launch routes wake's output to ~/.local/share/dux-amq/wake-<me>.log
# and probes survival; soft-fails so a wake glitch can't block claude
# (set DUX_AMQ_WAKE_STRICT=1 for hard-fail).
wake_launch "$ME" "$ROOT" raw || warn "claude-amq: continuing without wake"

exec amq coop exec --no-wake --no-init --root "$ROOT" --me "$ME" claude -- "${EXTRA[@]}" "$@"
