#!/usr/bin/env bash
# claude-amq: launch Claude Code with AMQ co-op identity.
#
# Identity defaults to the git branch of CWD (= dux worktree name);
# falls back to "claude-<pid>" when not in a git worktree.
# Skips AMQ wrapping for oneshot (-p / --print) invocations.
# Uses the global queue at $AMQ_GLOBAL_ROOT and never auto-creates .amqrc
# in the worktree.
#
# Optional session-history seeding (OFF by default — see notes below):
#   Set CLAUDE_AMQ_SEED_FROM_PARENT=1 to enable. Be aware: rsync clones the
#   parent worktree's full Claude history (~100 MB on heavy repos) — disk
#   amplification N×, possible token-billing escalation, and cross-worktree
#   info leak (parent transcripts may carry secrets/PII from a different
#   feature). Pair with `resume_args = ["--resume"]` in dux config if used.
#   Avoid combining with `--continue`: the latest parent session may carry
#   a deferred-tool marker that --continue refuses.
set -euo pipefail

# Returns 0 when $PWD is *inside* the dux worktrees directory, 1 otherwise.
#
# Why not a simple `[[ "$PWD" == "$DUX_HOME/worktrees/"* ]]` glob (the
# previous implementation): the glob also matches sibling directories
# whose names start with `worktrees`, e.g. `/data/state/dux/worktrees-evil/x`.
# That path-prefix vs path-segment distinction is the audit01 P0-5 bug.
#
# We canonicalize both sides via `realpath --` so a symlinked DUX_HOME
# or a CWD reached through a symlink still resolves correctly. The
# trailing slash on `pwd_real/` plus the `/*` pattern on the case label
# enforces a real path-segment boundary: `/foo/worktrees/` matches but
# `/foo/worktrees-evil/` does not.
#
# Linux note: `realpath --` requires GNU coreutils (the install.sh
# preflight enforces this). On macOS, `realpath` accepts the same flag
# starting with coreutils 9.x via brew; users on stock BSD realpath
# need `brew install coreutils` and either alias or set PATH so that
# `grealpath`/GNU realpath wins.
is_dux_worktree() {
  local pwd_real worktrees_real
  pwd_real=$(realpath -- "$PWD" 2>/dev/null)        || return 1
  worktrees_real=$(realpath -- "${DUX_HOME:-/data/state/dux}/worktrees" 2>/dev/null) || return 1
  case "$pwd_real/" in
    "$worktrees_real"/*) return 0 ;;
    *)                   return 1 ;;
  esac
}

for arg in "$@"; do
  case "$arg" in
    -p|--print|--bare) exec claude "$@" ;;
  esac
done

seed_session_history() {
  # OFF by default. Set CLAUDE_AMQ_SEED_FROM_PARENT=1 to enable.
  [[ "${CLAUDE_AMQ_SEED_FROM_PARENT:-}" == "1" ]] || return 0

  local git_dir git_common_dir main_worktree
  git_dir=$(git -C "$PWD" rev-parse --absolute-git-dir 2>/dev/null) || return 0
  git_common_dir=$(git -C "$PWD" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 0
  [[ "$git_dir" == "$git_common_dir" ]] && return 0
  main_worktree=$(git -C "$PWD" worktree list --porcelain 2>/dev/null \
    | awk '/^worktree / {print $2; exit}')
  [[ -z "$main_worktree" || "$main_worktree" == "$PWD" ]] && return 0

  # Encode each path with the shared encoder script (single source of
  # truth — see dux-amq/scripts/encode-claude-project-dir). The previous
  # inline `sed` only handled `/` and `_`; in reality Claude Code rewrites
  # every char outside [A-Za-z0-9-] to `-`, so paths containing `.`,
  # spaces, or other punctuation seeded into the wrong directory and the
  # parent transcripts were silently never picked up.
  if ! command -v encode-claude-project-dir >/dev/null 2>&1; then
    printf 'claude-amq: encode-claude-project-dir not on PATH; skipping seed\n' >&2
    return 0
  fi
  # `--` guards against pathological paths that begin with `-`. We also
  # capture $PWD / $main_worktree via `printf '%s'` (P2-3) before passing
  # to the encoder — `echo` would interpret a leading `-n` / `-e` as flags.
  local enc_self enc_main self_dir main_dir pwd_str main_str
  pwd_str=$(printf '%s' "$PWD")
  main_str=$(printf '%s' "$main_worktree")
  enc_self=$(encode-claude-project-dir -- "$pwd_str") || return 0
  enc_main=$(encode-claude-project-dir -- "$main_str") || return 0
  self_dir="$HOME/.claude/projects/$enc_self"
  main_dir="$HOME/.claude/projects/$enc_main"

  [[ ! -d "$main_dir" ]] && return 0
  if compgen -G "$self_dir/*.jsonl" >/dev/null 2>&1; then
    return 0
  fi

  mkdir -p "$self_dir"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a "$main_dir"/ "$self_dir"/ 2>/dev/null || true
  else
    cp -r "$main_dir"/. "$self_dir"/ 2>/dev/null || true
  fi
  local n
  n=$(find "$self_dir" -name '*.jsonl' 2>/dev/null | wc -l)
  echo "claude-amq: seeded $n past sessions from $main_worktree" >&2
}
seed_session_history || true

ME="${AM_ME:-}"
# Identity priority:
#   1. AM_ME from env (explicit override)
#   2. dux worktree dir basename — stable per-pane and unique, even if the
#      git branch was renamed or checked out to something unexpected
#   3. git branch (legacy fallback)
#   4. claude-<pid> (no-context fallback)
if [[ -z "$ME" ]] && is_dux_worktree; then
  ME=$(basename "$PWD")
fi
if [[ -z "$ME" ]]; then
  ME=$(git -C "$PWD" branch --show-current 2>/dev/null || true)
fi
[[ -z "$ME" ]] && ME="claude-$$"
# AMQ requires lowercase agent handles.
ME=$(printf '%s' "$ME" | tr '[:upper:]' '[:lower:]' | sed 's|[^a-z0-9_-]|-|g; s|^-\+||; s|-\+$||')

ROOT="${AMQ_GLOBAL_ROOT:-/data/state/amq}"

# YOLO is OPT-IN. Set CLAUDE_AMQ_YOLO=1 (or legacy CLAUDE_YOLO=1) to enable.
# Anthropic CVEs in 2025–26 (CVE-2025-59536 et al) targeted credential
# exfil through this attack class — default-deny is mandatory in prod.
EXTRA=()
if [[ "${CLAUDE_AMQ_YOLO:-${CLAUDE_YOLO:-}}" == "1" ]]; then
  EXTRA+=(--dangerously-skip-permissions)
  printf 'claude-amq: YOLO enabled — tool calls will not prompt\n' >&2
fi

# Transitional warning for users who set the legacy opt-out variable.
# CLAUDE_AMQ_SAFE used to disable YOLO; since YOLO is now opt-in, the
# variable is meaningless and silently keeping it set hides intent.
if [[ -n "${CLAUDE_AMQ_SAFE:-}" ]]; then
  printf 'claude-amq: CLAUDE_AMQ_SAFE is deprecated; YOLO is now opt-in via CLAUDE_AMQ_YOLO\n' >&2
fi

# Audit02 P0-K (T2): route incoming messages through `amq-receive-verify`
# so unsigned / replay / wrong-MAC envelopes are dropped before they can
# reach the agent's TTY. The verifier exits 0 with a stderr warning on
# rejection, so amq wake stays alive across bad messages.
#
# Stderr is captured to a per-pane log (audit01 P1-2 hygiene) instead of
# being dropped to /dev/null — `>2>/dev/null` previously hid the
# "[amq-verify] dropping unsigned" lines that are the entire signal of
# this phase actually doing its job.
#
# Known upstream gap (AMQ v0.34.0): `--inject-via` passes the wake
# *notification preview* to the executable as the final argv element
# and does not pipe the message body to stdin. `amq-receive-verify`
# reads stdin, so under v0.34.0 every wake invocation hits its
# "[amq-verify] no envelope on stdin" branch and the wake notification
# is never injected into the TTY. That is functionally equivalent to
# silencing wake notifications until the upstream issue lands stdin
# piping (or until we add a drain-side hook that fetches the body and
# pipes it through). The security goal of this phase — *blocking spoofed
# unsigned messages from being injected* — still holds because the
# verifier drops them. See the upstream issue NOTE in the commit body
# of audit02/08-amq-message-auth.
mkdir -p "$HOME/.local/share/dux-amq" 2>/dev/null || true
amq wake --me "$ME" --root "$ROOT" \
  --inject-via amq-receive-verify \
  </dev/tty >/dev/null 2>"$HOME/.local/share/dux-amq/wake-$ME.log" &

exec amq coop exec --no-wake --no-init --root "$ROOT" --me "$ME" claude -- ${EXTRA[@]+"${EXTRA[@]}"} "$@"
