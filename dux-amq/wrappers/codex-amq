#!/usr/bin/env bash
# codex-amq: launch Codex with AMQ co-op identity (worktree-scoped).
# Skips AMQ for oneshot ("exec ...") invocations used by dux for commit messages.
# Uses the global queue at $AMQ_GLOBAL_ROOT.
set -euo pipefail

# See claude-amq for the full rationale on path-segment vs prefix
# containment (audit01 P0-5). `realpath --` requires GNU coreutils;
# install.sh preflights it.
is_dux_worktree() {
  local pwd_real worktrees_real
  pwd_real=$(realpath -- "$PWD" 2>/dev/null)        || return 1
  worktrees_real=$(realpath -- "${DUX_HOME:-/data/state/dux}/worktrees" 2>/dev/null) || return 1
  case "$pwd_real/" in
    "$worktrees_real"/*) return 0 ;;
    *)                   return 1 ;;
  esac
}

if [[ "${1:-}" == "exec" ]]; then
  exec codex "$@"
fi

ME="${AM_ME:-}"
if [[ -z "$ME" ]] && is_dux_worktree; then
  ME=$(basename "$PWD")
fi
if [[ -z "$ME" ]]; then
  ME=$(git -C "$PWD" symbolic-ref --quiet --short HEAD 2>/dev/null || true)
fi
[[ -z "$ME" ]] && ME="codex-$$"
ME=$(printf '%s' "$ME" | tr '[:upper:]' '[:lower:]' | sed 's|[^a-z0-9_-]|-|g; s|^-\+||; s|-\+$||')

# Export AM_ME so descendants of `amq wake` (notably the inject-bridge)
# can identify the receiver. See claude-amq for full rationale.
export AM_ME="$ME"

ROOT="${AMQ_GLOBAL_ROOT:-/data/state/amq}"

register_amq_handle() {
  local cfg="$ROOT/meta/config.json"
  local lock="$ROOT/meta/config.lock"
  local tmp

  mkdir -p "$ROOT/meta" "$ROOT/agents/$ME" 2>/dev/null || true
  [[ -f "$cfg" ]] || return 0
  command -v jq >/dev/null 2>&1 || return 0

  (
    command -v flock >/dev/null 2>&1 && flock 9
    tmp="$cfg.tmp.$$"
    if jq --arg me "$ME" '.agents = ((.agents // []) + [$me] | unique)' "$cfg" >"$tmp"; then
      mv "$tmp" "$cfg"
    else
      rm -f "$tmp"
    fi
  ) 9>"$lock" 2>/dev/null || true
}

# Audit02 P1-F: identity collision detection. See claude-amq for full
# rationale. Uses atomic symlink creation so concurrent wrappers can't
# both succeed in claiming the same handle.
ME_REGISTRATION="$ROOT/agents/$ME/.dux-amq-source"
if [[ -L "$ME_REGISTRATION" || -f "$ME_REGISTRATION" ]]; then
  if [[ -L "$ME_REGISTRATION" ]]; then
    prev=$(readlink "$ME_REGISTRATION" 2>/dev/null || true)
  else
    prev=$(cat "$ME_REGISTRATION" 2>/dev/null || true)
  fi
  if [[ -n "$prev" && "$prev" != "$PWD" ]]; then
    printf '\033[1;31m!\033[0m [dux-amq] identity collision: %s already registered to %s (current: %s).\n' \
      "$ME" "$prev" "$PWD" >&2
    printf '            Rename one branch (avoid normalize-collisions) or set AM_ME explicitly.\n' >&2
    exit 1
  fi
fi
register_amq_handle
rm -f "$ME_REGISTRATION" 2>/dev/null || true
ln -s "$PWD" "$ME_REGISTRATION" 2>/dev/null || true

# Audit02 P0-K (T2) + Phase 13 (audit01 P1-1): route through verify+
# bridge. See claude-amq for the full rationale on TIOCSTI fallback.
LOG_DIR="$HOME/.local/share/dux-amq"
mkdir -p "$LOG_DIR" 2>/dev/null || true
WAKE_LOG="$LOG_DIR/wake-$ME.log"
WAKE_PID="$LOG_DIR/wake-$ME.pid"

STATE_ROOT="${STATE_ROOT:-/data/state}"
LOCAL_BIN="${LOCAL_BIN:-$HOME/.local/bin}"

# Reap a stale wake daemon from a prior invocation for the same $ME.
# See claude-amq for full rationale: without this, re-running the wrapper
# spawns a duplicate daemon causing double-delivery of wake notifications.
reap_stale_wake() {
  [[ -f "$WAKE_PID" ]] || return 0
  local old_pid
  old_pid=$(cat "$WAKE_PID" 2>/dev/null) || return 0
  [[ -z "$old_pid" ]] && return 0
  if kill -0 "$old_pid" 2>/dev/null; then
    local cmdline=""
    if [[ -r "/proc/$old_pid/cmdline" ]]; then
      cmdline=$(tr '\0' ' ' < "/proc/$old_pid/cmdline" 2>/dev/null || true)
    fi
    if [[ "$cmdline" == *amq*wake* ]]; then
      kill "$old_pid" 2>/dev/null || true
      local i=0
      while (( i < 5 )) && kill -0 "$old_pid" 2>/dev/null; do
        sleep 0.1
        (( i++ )) || true
      done
    fi
  fi
  rm -f "$WAKE_PID"
}
reap_stale_wake

INJECT_MODE="${DUX_AMQ_INJECT_MODE:-}"
if [[ -z "$INJECT_MODE" ]]; then
  if [[ -f "$STATE_ROOT/dux/.tiocsti-state" ]]; then
    INJECT_MODE="via"
  else
    INJECT_MODE="raw"
  fi
fi

# Audit02 P1-B: setsid + disown + PID file so wake survives parent
# shell hangup. See claude-amq for full rationale.
case "$INJECT_MODE" in
  raw)
    setsid amq wake --me "$ME" --root "$ROOT" --inject-mode raw \
      </dev/tty >>"$WAKE_LOG" 2>&1 &
    disown
    echo $! > "$WAKE_PID"
    ;;
  via)
    BRIDGE="$LOCAL_BIN/dux-amq-inject-bridge"
    if [[ ! -x "$BRIDGE" ]]; then
      BRIDGE=$(command -v dux-amq-inject-bridge 2>/dev/null || true)
    fi
    if [[ -n "$BRIDGE" && -x "$BRIDGE" ]]; then
      setsid amq wake --me "$ME" --root "$ROOT" --inject-via "$BRIDGE" \
        >>"$WAKE_LOG" 2>&1 &
      disown
      echo $! > "$WAKE_PID"
    else
      printf 'codex-amq: dux-amq-inject-bridge not found; wake disabled\n' >&2
    fi
    ;;
  *)
    printf 'codex-amq: DUX_AMQ_INJECT_MODE=%q not understood; using raw\n' "$INJECT_MODE" >&2
    setsid amq wake --me "$ME" --root "$ROOT" --inject-mode raw \
      </dev/tty >>"$WAKE_LOG" 2>&1 &
    disown
    echo $! > "$WAKE_PID"
    ;;
esac

# YOLO is OPT-IN. Set CODEX_AMQ_YOLO=1 (or legacy CLAUDE_YOLO=1, kept for
# backwards compat with the old "one switch flips both panes" UX) to pass
# --dangerously-bypass-approvals-and-sandbox. Default-deny matches the
# Anthropic 2025–26 CVE mitigation class — see claude-amq for context.
CODEX_EXTRA=()
if [[ "${CODEX_AMQ_YOLO:-${CLAUDE_YOLO:-}}" == "1" ]]; then
  CODEX_EXTRA+=(--dangerously-bypass-approvals-and-sandbox)
  printf 'codex-amq: YOLO enabled — sandbox bypass active\n' >&2
fi

# audit03 Phase 01 §15: per-session system-prompt override.
#
# dux exports DUX_SYSTEM_PROMPT for sessions whose operator set a
# system prompt in the session settings modal. Codex (verified against
# `codex --help` for the current release) does NOT expose a CLI flag
# equivalent to claude's `--append-system-prompt` — its system prompt
# is set via `~/.codex/instructions.md` (process-global) or the `-c`
# config-override mechanism (which only takes TOML keys, not free-form
# text). There is no per-invocation safe way to inject the text without
# rewriting that file, which would race with other concurrent codex
# sessions on the same host.
#
# Until codex grows an `--append-system-prompt` (or equivalent) flag,
# we warn-and-drop: log a single line to stderr so the operator
# learns their setting was a no-op for this provider, and pass nothing
# to codex (NEVER pass an unsupported flag).
if [[ -n "${DUX_SYSTEM_PROMPT:-}" ]]; then
  printf 'codex-amq: DUX_SYSTEM_PROMPT set but codex has no equivalent flag; ignoring\n' >&2
fi

exec amq coop exec --no-wake --no-init --root "$ROOT" --me "$ME" codex -- ${CODEX_EXTRA[@]+"${CODEX_EXTRA[@]}"} "$@"
