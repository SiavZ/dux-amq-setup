#!/usr/bin/env bash
# codex-amq: launch Codex with AMQ co-op identity (worktree-scoped).
# Skips AMQ for oneshot ("exec ...") invocations used by dux for commit messages.
# Uses the global queue at $AMQ_GLOBAL_ROOT.
set -euo pipefail

# See claude-amq for the full rationale on path-segment vs prefix
# containment (audit01 P0-5). `realpath --` requires GNU coreutils;
# install.sh preflights it.
is_dux_worktree() {
  local pwd_real worktrees_real
  pwd_real=$(realpath -- "$PWD" 2>/dev/null)        || return 1
  worktrees_real=$(realpath -- "${DUX_HOME:-/data/state/dux}/worktrees" 2>/dev/null) || return 1
  case "$pwd_real/" in
    "$worktrees_real"/*) return 0 ;;
    *)                   return 1 ;;
  esac
}

if [[ "${1:-}" == "exec" ]]; then
  exec codex "$@"
fi

ME="${AM_ME:-}"
if [[ -z "$ME" ]] && is_dux_worktree; then
  ME=$(basename "$PWD")
fi
if [[ -z "$ME" ]]; then
  ME=$(git -C "$PWD" branch --show-current 2>/dev/null || true)
fi
[[ -z "$ME" ]] && ME="codex-$$"
ME=$(printf '%s' "$ME" | tr '[:upper:]' '[:lower:]' | sed 's|[^a-z0-9_-]|-|g; s|^-\+||; s|-\+$||')

ROOT="${AMQ_GLOBAL_ROOT:-/data/state/amq}"

# Audit02 P0-K (T2) + Phase 13 (audit01 P1-1): route through verify+
# bridge. See claude-amq for the full rationale on TIOCSTI fallback.
mkdir -p "$HOME/.local/share/dux-amq" 2>/dev/null || true
WAKE_LOG="$HOME/.local/share/dux-amq/wake-$ME.log"

STATE_ROOT="${STATE_ROOT:-/data/state}"
LOCAL_BIN="${LOCAL_BIN:-$HOME/.local/bin}"

INJECT_MODE="${DUX_AMQ_INJECT_MODE:-}"
if [[ -z "$INJECT_MODE" ]]; then
  if [[ -f "$STATE_ROOT/dux/.tiocsti-state" ]]; then
    INJECT_MODE="via"
  else
    INJECT_MODE="raw"
  fi
fi

case "$INJECT_MODE" in
  raw)
    amq wake --me "$ME" --root "$ROOT" --inject-mode raw \
      </dev/tty 2>"$WAKE_LOG" &
    ;;
  via)
    BRIDGE="$LOCAL_BIN/dux-amq-inject-bridge"
    if [[ ! -x "$BRIDGE" ]]; then
      BRIDGE=$(command -v dux-amq-inject-bridge 2>/dev/null || true)
    fi
    if [[ -n "$BRIDGE" && -x "$BRIDGE" ]]; then
      amq wake --me "$ME" --root "$ROOT" --inject-via "$BRIDGE" \
        2>"$WAKE_LOG" &
    else
      printf 'codex-amq: dux-amq-inject-bridge not found; wake disabled\n' >&2
    fi
    ;;
  *)
    printf 'codex-amq: DUX_AMQ_INJECT_MODE=%q not understood; using raw\n' "$INJECT_MODE" >&2
    amq wake --me "$ME" --root "$ROOT" --inject-mode raw \
      </dev/tty 2>"$WAKE_LOG" &
    ;;
esac

# YOLO is OPT-IN. Set CODEX_AMQ_YOLO=1 (or legacy CLAUDE_YOLO=1, kept for
# backwards compat with the old "one switch flips both panes" UX) to pass
# --dangerously-bypass-approvals-and-sandbox. Default-deny matches the
# Anthropic 2025–26 CVE mitigation class — see claude-amq for context.
CODEX_EXTRA=()
if [[ "${CODEX_AMQ_YOLO:-${CLAUDE_YOLO:-}}" == "1" ]]; then
  CODEX_EXTRA+=(--dangerously-bypass-approvals-and-sandbox)
  printf 'codex-amq: YOLO enabled — sandbox bypass active\n' >&2
fi

exec amq coop exec --no-wake --no-init --root "$ROOT" --me "$ME" codex -- ${CODEX_EXTRA[@]+"${CODEX_EXTRA[@]}"} "$@"
