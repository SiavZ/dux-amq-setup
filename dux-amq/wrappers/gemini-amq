#!/usr/bin/env bash
# gemini-amq: launch Gemini CLI with AMQ co-op identity (worktree-scoped).
# Skips AMQ wrapping for oneshot (-p / --print) invocations.
# Uses the global queue at $AMQ_GLOBAL_ROOT.
set -euo pipefail

# See claude-amq for the full rationale on path-segment vs prefix
# containment (audit01 P0-5). `realpath --` requires GNU coreutils;
# install.sh preflights it.
is_dux_worktree() {
  local pwd_real worktrees_real
  pwd_real=$(realpath -- "$PWD" 2>/dev/null)        || return 1
  worktrees_real=$(realpath -- "${DUX_HOME:-/data/state/dux}/worktrees" 2>/dev/null) || return 1
  case "$pwd_real/" in
    "$worktrees_real"/*) return 0 ;;
    *)                   return 1 ;;
  esac
}

for arg in "$@"; do
  case "$arg" in
    -p|--print) exec gemini "$@" ;;
  esac
done

ME="${AM_ME:-}"
if [[ -z "$ME" ]] && is_dux_worktree; then
  ME=$(basename "$PWD")
fi
if [[ -z "$ME" ]]; then
  ME=$(git -C "$PWD" branch --show-current 2>/dev/null || true)
fi
[[ -z "$ME" ]] && ME="gemini-$$"
ME=$(printf '%s' "$ME" | tr '[:upper:]' '[:lower:]' | sed 's|[^a-z0-9_-]|-|g; s|^-\+||; s|-\+$||')

ROOT="${AMQ_GLOBAL_ROOT:-/data/state/amq}"

# Audit02 P0-K (T2): route through amq-receive-verify so unsigned /
# replay / wrong-MAC envelopes are dropped. See claude-amq for the
# full rationale and the AMQ v0.34.0 `--inject-via` upstream gap.
# Note: --inject-via supersedes --inject-mode (mode is the in-process
# TIOCSTI path; --inject-via runs an external executable instead).
mkdir -p "$HOME/.local/share/dux-amq" 2>/dev/null || true
amq wake --me "$ME" --root "$ROOT" \
  --inject-via amq-receive-verify \
  </dev/tty >/dev/null 2>"$HOME/.local/share/dux-amq/wake-$ME.log" &

exec amq coop exec --no-wake --no-init --root "$ROOT" --me "$ME" gemini -- "$@"
