#!/usr/bin/env bash
# gemini-amq: launch Gemini CLI with AMQ co-op identity (worktree-scoped).
# Skips AMQ wrapping for oneshot (-p / --print) invocations.
# Uses the global queue at $AMQ_GLOBAL_ROOT.
set -euo pipefail

for arg in "$@"; do
  case "$arg" in
    -p|--print) exec gemini "$@" ;;
  esac
done

ME="${AM_ME:-}"
# Realpath-canonicalised containment: '$DUX_HOME/worktrees/' must be a
# strict ancestor of the resolved CWD. The boundary '/' rejects sibling
# dirs like '$DUX_HOME/worktrees-evil/x' (audit01 P0-5).
if [[ -z "$ME" ]]; then
  _DUX_WTS=$(realpath -m "${DUX_HOME:-/data/state/dux}/worktrees")
  _PWD_REAL=$(realpath -m "$PWD")
  if [[ "$_PWD_REAL" == "$_DUX_WTS"/* ]]; then
    ME=$(basename "$_PWD_REAL")
  fi
  unset _DUX_WTS _PWD_REAL
fi
if [[ -z "$ME" ]]; then
  ME=$(git -C "$PWD" branch --show-current 2>/dev/null || true)
fi
[[ -z "$ME" ]] && ME="gemini-$$"
ME=$(printf '%s' "$ME" | tr '[:upper:]' '[:lower:]' | sed 's|[^a-z0-9_-]|-|g; s|^-\+||; s|-\+$||')

ROOT="${AMQ_GLOBAL_ROOT:-/data/state/amq}"

# Gemini is crossterm-based; paste mode is the right default. We still
# start wake explicitly so coop exec doesn't spawn its own (which would
# otherwise double up on injection). Stdin must be /dev/tty (see
# claude-amq for full explanation).
amq wake --me "$ME" --root "$ROOT" --inject-mode auto </dev/tty >/dev/null 2>&1 &

exec amq coop exec --no-wake --no-init --root "$ROOT" --me "$ME" gemini -- "$@"
