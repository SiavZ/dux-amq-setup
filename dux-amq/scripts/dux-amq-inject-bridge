#!/usr/bin/env bash
# dux-amq-inject-bridge — TIOCSTI-disabled fallback for `amq wake`
# (audit02 Phase 13, audit01 P1-1; receiver-keyed queue rev added when
# the dux-side drainer was implemented; verify-opt-in rev added when
# T2 was reclassified as accepted-risk in single-user-VM mode).
#
# AMQ v0.34.0's `--inject-mode raw` calls `ioctl(TIOCSTI)` directly and
# silently fails on Linux ≥ 6.2 / Ubuntu 24.04 / Debian 12+ (kernels
# built with CONFIG_LEGACY_TIOCSTI=n). The wrappers detect the kernel
# state at install time (sentinel at $STATE_ROOT/dux/.tiocsti-state)
# and switch to `--inject-via "$LOCAL_BIN/dux-amq-inject-bridge"`. AMQ
# spawns this script with the wake notification preview as the FINAL
# argv element ($1 here).
#
# Flow:
#   1. (Optional) Verify the envelope through `amq-receive-verify` when
#      `DUX_AMQ_VERIFY=1`. Verification was originally mandatory
#      (audit02 Phase 08, T2: "compromised peer spoofs identity"), but
#      our trust model in SECURITY.md states all panes share the same
#      Linux user, $HOME, and FS perms — i.e. there's no boundary
#      between peers in the first place. A peer with same-UID access
#      can `cat ~/.local/share/dux-amq/amq-secret` (mode 0600 on the
#      same $HOME) or `ptrace`/`LD_PRELOAD` the signer. Per Linus
#      ("there is a complete lack of a security boundary between
#      processes of the same user") and MIT 6.828, HMAC against a
#      same-UID adversary is not a meaningful boundary. So strict
#      verification is now opt-in for environments that genuinely
#      bridge a trust boundary (e.g. wake notifications proxied across
#      hosts) — most users want skip mode.
#
#      Skip mode (default): if the envelope starts with `DUX1\t` we
#      transparently extract the inner body without checking the MAC
#      (so signed senders still work end-to-end); otherwise we use the
#      argv as-is. Either way we deliver SOMETHING — that's the entire
#      point of the change.
#
#      Strict mode (`DUX_AMQ_VERIFY=1`): the original behaviour. We
#      call `amq-receive-verify` and drop on any failure (unsigned,
#      stale, replayed, MAC mismatch). dux exports this env var when
#      `[amq.inject].verify_envelope = true` in `config.toml`.
#
#   2. Inject the body into the dux pane. Strategy selection:
#        a. When DUX_PANE is set (dux is the parent process tree), we
#           ALWAYS go to the file queue. The dux-side drainer reads it
#           and types into the agent's PTY only when the agent is idle
#           — this avoids the "stuck in input field" failure mode
#           where tmux send-keys delivers the body but the trailing
#           Enter is dropped because Claude Code's Ink input is in
#           non-accepting state during streaming.
#        b. Otherwise, when $TMUX is set, use `tmux send-keys`. This
#           covers operators running plain claude/codex under tmux
#           outside dux, where there's no other consumer and the
#           streaming-state race is less common.
#        c. Otherwise, write to the file queue and let an operator
#           (or a future polling consumer) recover the body manually.
#
# Queue layout (receiver-keyed):
#   $QUEUE_DIR/<receiver>/<ts>.msg     — addressed messages
#   $QUEUE_DIR/_unrouted/<ts>.msg      — fallback when AM_ME is unset
#                                         or sanitises to empty
#
# `<receiver>` is `$AM_ME` after the same sanitisation as the wrapper
# (lowercase, [a-z0-9_-] only). The leading `_` on `_unrouted` makes it
# disjoint from any sanitised branch name (which can never start with
# `_` after the regex strips it). The dux drainer treats `_unrouted/`
# specially: it routes to the currently selected session with a status
# warning instead of dropping.
#
# Exit status is always 0 on the happy path AND on every soft-failure
# branch (silent verify rejection in strict mode, missing tmux, full
# filesystem). The upstream AMQ contract says: a non-zero
# `--inject-via` exit means "retry this message later", which we never
# want for a malformed/spoofed body. Setup errors that *would* benefit
# from a retry aren't present here (no network calls, no auth tokens
# to refresh) — every failure mode is either "the message is bad" or
# "the host is bad", and neither is helped by a retry.
set -euo pipefail

ENVELOPE="${1:-}"

# Mode selection. Default is skip-verify, matching the trust model in
# SECURITY.md (T2 accepted-risk in single-user-VM mode). dux exports
# DUX_AMQ_VERIFY=1 when the operator opts back into strict mode via
# `[amq.inject].verify_envelope = true`. Outside dux, env unset =
# default = skip.
VERIFY_MODE="${DUX_AMQ_VERIFY:-0}"

# Empty envelope is always a no-op regardless of mode. Stays exit 0
# because retrying empty input would just produce another empty input.
if [[ -z "$ENVELOPE" ]]; then
  exit 0
fi

if [[ "$VERIFY_MODE" == "1" ]]; then
  # ---- Strict mode (opt-in) ----
  #
  # Run the verifier with stdin closed (`</dev/null`) so it picks the
  # argv branch deterministically. Empty stdout = soft-drop (unsigned,
  # replayed, stale, MAC mismatch); we exit 0 silently per AMQ
  # `--inject-via` contract.
  if ! command -v amq-receive-verify >/dev/null 2>&1; then
    printf '[inject-bridge] DUX_AMQ_VERIFY=1 but amq-receive-verify not on PATH; dropping\n' >&2
    exit 0
  fi
  body=$(amq-receive-verify "$ENVELOPE" </dev/null 2>/dev/null) || body=""
  if [[ -z "$body" ]]; then
    # Verifier dropped the message; it logged the reason to its own
    # stderr (which the wrapper redirects to wake-$ME.log).
    exit 0
  fi
else
  # ---- Skip mode (default) ----
  #
  # Transparently unwrap a DUX1 envelope when present so signed
  # senders (legacy `amq-send-signed` callers) keep working without
  # the receiver agent seeing the raw `DUX1\talice\tbob\t...` text.
  # Plain `amq send` bodies pass through as-is.
  #
  # Envelope shape (TAB-delimited, see `amq-send-signed`):
  #   DUX1\t<sender>\t<recipient>\t<utc-iso>\t<nonce>\t<mac>\t<body>
  #
  # Inner body may itself contain TABs (see audit02 P0-K). We can't
  # use `cut -f7-` reliably without GNU `cut`, so do the split in
  # bash: skip exactly six TAB-separated header fields, return the
  # rest. Keeps macOS portability without the verifier dependency.
  if [[ "$ENVELOPE" == DUX1$'\t'* ]]; then
    rest="${ENVELOPE#DUX1$'\t'}"
    # Skip 5 more fields: sender, recipient, ts, nonce, mac.
    for _ in 1 2 3 4 5; do
      next="${rest#*$'\t'}"
      if [[ "$next" == "$rest" ]]; then
        # Malformed envelope (fewer than 7 fields). Treat as raw.
        rest="$ENVELOPE"
        break
      fi
      rest="$next"
    done
    body="$rest"
  else
    body="$ENVELOPE"
  fi
fi

# Strip the trailing newline emitted by `amq-receive-verify` (strict
# mode) or any LF the upstream attached (skip mode). Bash parameter
# expansion `${var%$'\n'}` removes exactly one trailing LF.
send_body="${body%$'\n'}"

# `amq wake` sends an interrupt command before the human-readable
# interrupt notice for urgent interrupt-labeled messages. Under dux the
# bridge writes to a file queue, so a raw Ctrl+C byte cannot actually
# interrupt the agent; it only creates an invalid queue file that the
# Rust drainer must reject. Drop that transport-only signal and let the
# following interrupt notice carry the actionable prompt.
if [[ "$send_body" == $'\003' ]]; then
  exit 0
fi

# Resolve receiver from $AM_ME, applying the same sanitisation the
# wrappers use to produce the AMQ handle. This keeps the queue path
# disjoint from any directory traversal attempt: only [a-z0-9_-] can
# survive, and we strip leading/trailing dashes.
sanitised_receiver=""
if [[ -n "${AM_ME:-}" ]]; then
  sanitised_receiver=$(printf '%s' "$AM_ME" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's|[^a-z0-9_-]|-|g; s|^-\+||; s|-\+$||')
fi
RECEIVER="${sanitised_receiver:-_unrouted}"

# Step 2a — under dux, always go to the queue.
#
# `DUX_PANE` is set by dux when it spawns the agent's PTY (see
# `apply_terminal_env` in src/pty.rs). Children of that PTY (the
# wrapper, then `setsid amq wake`, then the inject-bridge spawned
# by AMQ) inherit it. When present, we skip tmux entirely and let
# the dux-side drainer deliver the body — it knows when the agent
# is idle and can type the body + submit reliably.
under_dux=0
if [[ -n "${DUX_PANE:-}" ]]; then
  under_dux=1
fi

# Under dux, do not make the model execute a second command just to read
# the message. Convert the wake notification into the actual AMQ drain
# output, then queue that output for the dux-side drainer to submit to
# the agent. This keeps `inbox/new` from accumulating when an agent sees
# a wake prompt but does not follow the "run amq drain" instruction.
if (( under_dux == 1 )) && [[ -n "${AM_ROOT:-${AMQ_GLOBAL_ROOT:-}}" ]] && command -v amq >/dev/null 2>&1; then
  ROOT="${AM_ROOT:-${AMQ_GLOBAL_ROOT:-/data/state/amq}}"
  drain_limit="${DUX_AMQ_DRAIN_LIMIT:-20}"
  if drain_out=$(amq drain --root "$ROOT" --me "$RECEIVER" --include-body --limit "$drain_limit" 2>&1); then
    if [[ -z "$drain_out" ]]; then
      # Another wake/drain path already consumed the message. Avoid
      # injecting stale "Drain with..." notices that create confusion.
      exit 0
    fi
    send_body="$drain_out"$'\n''Act on these AMQ messages now. Reply over AMQ when needed.'
  else
    printf '[inject-bridge] amq drain failed for %s: %s\n' "$RECEIVER" "$drain_out" >&2
  fi
fi

# The Rust drainer rejects unsafe control bytes. AMQ message bodies are
# peer-authored, so strip transport/control bytes before queueing the
# drain output; preserve TAB and LF because they are useful formatting.
send_body=$(printf '%s' "$send_body" | LC_ALL=C tr -d '\000-\010\013\014\015\016-\037\177')

# Step 2b — outside dux, prefer tmux send-keys when available.
#
# `DUX_TMUX_TARGET` lets the operator point at a specific pane (e.g.
# `mywindow:0.1`); the default of empty means "current pane of current
# window" — the same pane the wrapper is running in.
if (( under_dux == 0 )) && [[ -n "${TMUX:-}" ]] && command -v tmux >/dev/null 2>&1; then
  TARGET="${DUX_TMUX_TARGET:-}"
  if [[ -n "$TARGET" ]]; then
    tmux send-keys -t "$TARGET" -- "$send_body" Enter
  else
    tmux send-keys -- "$send_body" Enter
  fi
  exit 0
fi

# Step 2c — file queue (under dux always; outside dux as final
# fallback when tmux isn't available).
QUEUE_ROOT="$HOME/.local/share/dux-amq/inject-queue"
QUEUE_DIR="$QUEUE_ROOT/$RECEIVER"
mkdir -p "$QUEUE_DIR" 2>/dev/null || {
  printf '[inject-bridge] cannot create %s; dropping message\n' "$QUEUE_DIR" >&2
  exit 0
}
# Use mktemp for the final filename to guarantee uniqueness even when the
# system clock jumps backward (NTP correction, VM suspend/resume). The
# timestamp prefix preserves arrival-order sorting for the drainer; the
# random suffix from mktemp prevents collisions.
ts=$(date -u +%s%N 2>/dev/null) || ts=""
if [[ -z "$ts" || "$ts" == *N* ]]; then
  ts="$(date -u +%s)"
fi
# Use a temp + rename so a concurrent reader never sees a half-written
# file. The temp lives in the same receiver dir to keep the rename
# atomic across the FS boundary. The `.inflight.` prefix matches the
# pattern the dux drainer uses for its own in-flight reservation,
# letting both sides agree on what to skip during scans.
tmp=$(mktemp "$QUEUE_DIR/.inflight.XXXXXX") || exit 0
printf '%s\n' "$send_body" >"$tmp"
# Derive the final name from the temp's random suffix to stay unique.
suffix="${tmp##*.inflight.}"
target="$QUEUE_DIR/${ts}-${suffix}.msg"
mv -f "$tmp" "$target"
exit 0
